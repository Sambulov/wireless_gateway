# SUTO S111 Three-Phase Power Meter — Modbus Register Table
# Source: S111_Modbus-register-table_EN_V2025-2.pdf  Rev.2025-2
#
# Columns (tab-separated):
#   ALIAS           ADDR  RW   SIZE  TYPE      UNIT   DESCRIPTION
#
# RW:   R=read-only  W=direct FC16  WC=write via config instr (FC16 to reg 300+)
# SIZE: count of 16-bit Modbus registers
# ADDR: decimal, no address offset

# ── 1.9.1  Equipment parameters ───────────────────────────────────────────────
DeviceModel         60    R    10    UTF8      -      Device model string
SerialNo            70    R    2     UInt32    -      Serial number
AppVersion          72    R    1     UInt16    -      App version (format X.Y hi-byte.lo-byte)
DateTime            75    R/WC 4     DateTime  -      Reg75=Year Reg76=Month(b15:8)|Day(b7:0) Reg77=Hour(b15:8)|Min(b7:0) Reg78=Second

# ── 1.9.2  Communication parameters ──────────────────────────────────────────
SlaveAddress        80    R/WC 1     UInt16    -      Slave address 1-247
BaudRate            81    R/WC 1     UInt16    -      0=2400 1=4800 2=9600 3=19200 4=38400 5=57600 6=115200
Parity              82    R/WC 1     UInt16    -      0=None 1=Odd 2=Even
StopBit             83    R/WC 1     UInt16    -      0=1bit 1=2bit

# ── 1.9.3  Voltage and current phase sequence ─────────────────────────────────
PhaseSeqState       220   R    1     UInt16    -      0=both correct 1=voltage wrong 2=current wrong 3=both wrong

